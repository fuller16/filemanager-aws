# --- Application URLs / paths ---
APP_URL=https://onpoint.pinpoint.promo
ROOT_PATH=/var/www/html/staging-temp/public/order_files
MSG_PATH=/var/www/html/staging-temp/public/order_files/

# Host that is allowed to embed filemanager in an iframe (referer check + auth bypass)
ALLOWED_REFERER_HOST=onpoint.pinpoint.promo

# Brand logo shown on the login screen
BRAND_LOGO_URL=https://onpoint.pinpoint.promo/crm/dist/img/orange-logo.png

# --- Database (used by index.php auth) ---
DB_HOST=
DB_USER=
DB_PASS=
DB_NAME=
DB_PORT=

# --- Attachments storage used by msg/eml converters ---
ATTACHMENTS_PATH=/var/www/html/filemanager/attachments
ATTACHMENTS_URL=http://filemanager.pinpoint.promo/attachments

# --- Source roots used by converteps.php / convertpsd.php ---
IMAGICK_ATTACHMENTS_ROOT=/home/pinpointdev/Dropbox/filemanager/
IMAGICK_PUBLIC_ROOT=/home/pinpointdev/Dropbox/onpoint.pinpoint/public
